{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude StandUp",
  "version": "1.7.1",
  "identifier": "com.bachdx.claude-standup",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "monitor",
        "title": "",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bachdx2812/claude-standup/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4MjY1RjU1NkUxNDdCQTgKUldTb2V4UnVWVjhtT0pNTFlrS21OK21xRytXUUZjeHErVk1aVEgyanJsZ1MzanJkNGVYcy9oV0kK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "© 2026 bachdx2812",
    "shortDescription": "Watch your Claude Code sessions as a lively office.",
    "longDescription": "Native macOS app that surfaces your active Claude Code sessions as a lively office — one desk per session with live status, cost + context, and key decisions. Local-only, read-only, open source.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
