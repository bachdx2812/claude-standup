{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude StandUp",
  "version": "0.1.0",
  "identifier": "com.bachdx.claude-standup",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "monitor",
        "title": "Claude StandUp",
        "width": 880,
        "height": 600,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "DeveloperTool",
    "copyright": "© 2026 bachdx2812",
    "shortDescription": "Watch your Claude Code sessions as a lively office.",
    "longDescription": "Native macOS app that surfaces your active Claude Code sessions as a lively office — one desk per session with live status, cost + context, and key decisions. Local-only, read-only, open source.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
